# FreeAssist API — Environment Variables
# Copy to .env and fill in values for local dev
# In production: fly secrets set KEY=VALUE

# Database (Fly.io Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/freeassist

# Redis (Fly.io Redis / Upstash)
REDIS_URL=redis://localhost:6379/0

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change_me_in_production_use_openssl_rand_hex_32

# ML Models
INTENT_CLASSIFIER_PATH=./ml/models/intent_classifier/best
RAG_INDEX_DIR=./data/faiss_index
LLM_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
EMBED_MODEL_ID=dangvantuan/sentence-camembert-large
DEVICE=cpu   # cpu | cuda | mps

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=freeassist-dev

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
